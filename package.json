{
  "name": "plantoes-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:backend": "npm --prefix backend run start:dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma && npm run seed",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma && npm run seed",
    "seed": "npm --prefix backend run seed"
  },
  "devDependencies": {
    "concurrently": "^7.6.0",
    "prisma": "6.18.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^6.18.0",
    "dotenv": "^17.3.1",
    "pg": "^8.19.0"
  }
}
